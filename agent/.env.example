# Server API
SERVER_URL=http://localhost:5000
AGENT_API_KEY=another_random_secret_for_agent

# Gmail SMTP — for sending form emails and report delivery
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password

# Leadership email — receives the Monday Word doc
LEADERSHIP_EMAIL=leadership@ignis-innovation.com

# MongoDB (for Monday cron direct read)
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/ignis_reports
