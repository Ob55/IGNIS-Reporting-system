# MongoDB
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/ignis_reports

# JWT
JWT_SECRET=pick_any_long_random_string_change_this

# Server
PORT=5000

# Gmail SMTP — for setup emails and report delivery
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password

# Frontend URL (used in email links)
CLIENT_URL=http://localhost:5173

# Agent API key — agent uses this to call /api/form/generate-tokens
AGENT_API_KEY=another_random_secret_for_agent
